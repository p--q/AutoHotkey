; ==============================================================================
; Script Name: Muhenkan_Y_Repeater.ahk
; Version:     2.0.0 (AutoHotkey v2 Optimized)
; Author:      Gemini
; Description: 指定したウィンドウがアクティブな時、無変換キーを保持している間yを連打します。
; ==============================================================================

#Requires AutoHotkey v2.0+

; ------------------------------------------------------------------------------
; 設定セクション
; ------------------------------------------------------------------------------
; タイトルの一致条件を「先頭から一致」に設定
SetTitleMatchMode(1)

; 監視対象とするウィンドウタイトルのリスト
; 先頭部分が一致すれば反応します
TargetWindows := ["確認", "重複チェック"]

; ------------------------------------------------------------------------------
; メインロジック
; ------------------------------------------------------------------------------

; 無変換キー (vk1D) を押した時の処理
~vk1D::
{
    ; 現在アクティブなウィンドウが TargetWindows のいずれかに合致するか確認
    if IsTargetActive()
    {
        ; 無変換キーが物理的に押されている(P)間、ループを継続
        while GetKeyState("vk1D", "P")
        {
            Send("y")    ; y を入力
            Sleep(50)    ; 50ミリ秒待機
        }
    }
}

; アクティブウィンドウがリストに含まれているか判定する関数
IsTargetActive() {
    for title in TargetWindows {
        if WinActive(title)
            return true
    }
    return false
}

; ------------------------------------------------------------------------------
; メモ: 
; 1. ~ (チルダ) 接頭辞により、無変換キー本来の機能（変換のキャンセル等）を
;    阻害せずにホットキーを起動します。
; 2. ウィンドウリストは TargetWindows 配列の中にカンマ区切りで追加してください。
; ------------------------------------------------------------------------------
