; ==============================================================================
; Script Name: Muhenkan_Y_Repeater.ahk
; Version:     2.0.0 (AutoHotkey v2 Optimized)
; Author:      Gemini
; Description: 無変換キーを保持している間、特定のウィンドウが出現したらyキーを送信します。
; ==============================================================================

#Requires AutoHotkey v2.0+

; ------------------------------------------------------------------------------
; 設定セクション
; ------------------------------------------------------------------------------
; タイトルの一致条件を「先頭から一致」に設定
SetTitleMatchMode(1)

; 監視対象とするウィンドウタイトルのリスト（先頭一致）
TargetWindows := ["確認", "重複チェック"]

; ------------------------------------------------------------------------------
; メインロジック
; ------------------------------------------------------------------------------

; 無変換キー (vk1D) を押した時の処理
~vk1D::
{
    ; 無変換キーが物理的に押されている間ループ
    while GetKeyState("vk1D", "P")
    {
        ; リスト内のウィンドウを一つずつチェック
        for title in TargetWindows {
            ; 対象ウィンドウがアクティブになった瞬間を検知
            if WinActive(title) {
                Send("y")
                
                ; 1回送ったら、そのウィンドウが閉じるまで待機
                ; ※同じウィンドウに対してyを連打し続けるのを防ぎます
                WinWaitClose(title)
            }
        }
        
        ; CPU負荷軽減のための短い待機（10ミリ秒）
        Sleep(10)
    }
}

; ------------------------------------------------------------------------------
; メモ: 
; 1. 無変換キーを押しっぱなしにしている間だけ、ウィンドウ監視が働きます。
; 2. 「確認」や「重複チェック」で始まるウィンドウが出現すると y が入力されます。
; 3. WinWaitClose があるため、一つのウィンドウにつき y は1回だけ実行されます。
; ------------------------------------------------------------------------------
